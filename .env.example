# Base de données (Railway fournit automatiquement DATABASE_URL si tu ajoutes un service PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/artistlinks"

# JWT
JWT_SECRET="change-moi-en-une-longue-chaine-aleatoire"

# CinetPay
CINETPAY_API_KEY="ta_cle_api_cinetpay"
CINETPAY_SITE_ID="ton_site_id_cinetpay"
CINETPAY_NOTIFY_URL="https://ton-backend.up.railway.app/api/v1/payments/cinetpay/notify"
CINETPAY_RETURN_URL="https://ton-frontend.vercel.app/payment/success"

# Frontend (pour CORS)
FRONTEND_URL="https://ton-frontend.vercel.app"

# Serveur
PORT=3000
